---
import Section from "./Section.astro";
---

<Section>
  <div class="proposal-cta relative overflow-hidden rounded-[45px] bg-dark text-white mt-[123px] mb-[163px]">
    <!-- Orbs decorativos de fondo -->
    <div class="proposal-orb proposal-orb--1" aria-hidden="true"></div>
    <div class="proposal-orb proposal-orb--2" aria-hidden="true"></div>

    <!-- Contenido principal -->
    <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-10 p-[60px]">
      <!-- Texto y CTA -->
      <div class="flex flex-col gap-6 md:w-1/2">
        <h2 class="text-3xl font-medium text-white">Hagamos que las cosas pasen</h2>
        <p class="text-white/70 leading-relaxed">
          Contacta con nosotros hoy para obtener más información sobre cómo nuestros servicios pueden ayudar a que tu negocio crezca y tenga éxito en línea.
        </p>
        <a href="https://api.whatsapp.com/send?phone=50663536621&text=Hola,%20estoy%20interesado%20en%20los%20servicios%20de%20Pimenta%20Studio." target="_blank" class="btn-proposal w-fit">
          Agendar Reunión
        </a>
      </div>

      <!-- Elemento visual abstracto CSS -->
      <div class="proposal-visual hidden md:flex items-center justify-center md:w-1/2" aria-hidden="true">
        <div class="proposal-ring proposal-ring--outer"></div>
        <div class="proposal-ring proposal-ring--inner"></div>
        <div class="proposal-dot"></div>
      </div>
    </div>
  </div>
</Section>

<style>
  .proposal-orb--1 {
    position: absolute;
    top: -30%;
    right: 5%;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,147,39,0.18), transparent 70%);
    pointer-events: none;
  }

  .proposal-orb--2 {
    position: absolute;
    bottom: -40%;
    left: 0%;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,147,39,0.08), transparent 70%);
    pointer-events: none;
  }

  .proposal-visual {
    position: relative;
    width: 280px;
    height: 280px;
  }

  .proposal-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,147,39,0.3);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: float-slow 6s ease-in-out infinite;
  }

  .proposal-ring--outer {
    width: 240px;
    height: 240px;
  }

  .proposal-ring--inner {
    width: 160px;
    height: 160px;
    border-color: rgba(255,147,39,0.5);
    animation-duration: 4s;
    animation-direction: reverse;
  }

  .proposal-dot {
    position: absolute;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(255,147,39,0.25);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: float-fast 3s ease-in-out infinite;
  }

  .btn-proposal {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: var(--dark);
    font-weight: 500;
    padding: 1.25rem 2.25rem;
    border-radius: 0.75rem;
    transition: background 200ms ease-out, color 200ms ease-out, transform 200ms ease-out;
  }

  .btn-proposal:hover {
    background: var(--white);
    color: var(--dark);
    transform: scale(1.03);
  }
</style>
