---
import SectionTitle from "../ui/SectionTitle.astro";
import TeamCard from "../ui/TeamCard.astro";
import Section from "./Section.astro";

const description =
  "Somos un equipo apasionado por la tecnología y el diseño, comprometidos con el éxito de cada proyecto.";

// Team images
import p1 from "../../assets/team/t1.png";
import p2 from "../../assets/team/t2.png";
import p3 from "../../assets/team/t3.png";

const team = [
  {
    pic: p1,
    name: "Percy Benavides",
    role: "Director Creativo & Fundador",
    description:
      "Especialista en diseño UX/UI y estrategia de marca con más de 4 años liderando proyectos digitales.",
    link: "https://linkedin.com",
  },
  {
    pic: p2,
    name: "Jose Ramírez",
    role: "Director de Operaciones & Fundador",
    description:
      "Experto en gestión de proyectos y operaciones con enfoque en marketing digital y crecimiento de negocios.",
    link: "https://linkedin.com",
  },
  {
    pic: p3,
    name: "Edwin Delgado",
    role: "Director de Desarrollo & Fundador",
    description:
      "Desarrollador full-stack con más de 4 años construyendo aplicaciones web y sistemas SaaS escalables.",
    link: "https://linkedin.com",
  },
];
---

<Section id="about">
  <div class="mt-[140px]">
    <SectionTitle sectionTitle="Equipo" description={description} />
    <div
      class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3  gap-10 mb-28"
    >
      {
        team.map((member, index) => (
          <TeamCard
            key={index}
            pic={member.pic}
            name={member.name}
            role={member.role}
            description={member.description}
            link={member.link}
          />
        ))
      }
    </div>
  </div>
</Section>
