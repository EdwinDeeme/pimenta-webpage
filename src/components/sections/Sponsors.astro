---
import { Image } from "astro:assets";
import s1 from "../../assets/company/company-logo1.svg";
import s2 from "../../assets/company/company-logo2.svg";
import s3 from "../../assets/company/company-logo3.svg";
import s4 from "../../assets/company/company-logo4.svg";
import s5 from "../../assets/company/company-logo5.svg";
import s6 from "../../assets/company/company-logo6.svg";
import Section from "./Section.astro";

const sponsors = [
  { logo: s1, alt: "Astro" },
  { logo: s2, alt: "React" },
  { logo: s3, alt: "TailwindCSS" },
  { logo: s4, alt: "WordPress" },
  { logo: s5, alt: "Stripe" },
  { logo: s6, alt: "Supabase" },
];
---

<Section id="sponsors">
  <div class="sponsors-marquee-wrapper">
    <div class="sponsors-marquee" aria-label="Tecnologías que usamos">
      <div class="sponsors-track">
        {sponsors.map(s => <div class="sponsor-item"><Image src={s.logo} class="h-10 w-auto" alt={s.alt} loading="lazy" /></div>)}
      </div>
      <div class="sponsors-track" aria-hidden="true">
        {sponsors.map(s => <div class="sponsor-item"><Image src={s.logo} class="h-10 w-auto" alt={s.alt} loading="lazy" /></div>)}
      </div>
    </div>
  </div>
</Section>

<style>
  .sponsors-marquee-wrapper {
    overflow: hidden;
  }

  .sponsors-marquee {
    display: flex;
    width: max-content;
    animation: marquee var(--marquee-duration) linear infinite;
  }

  .sponsors-track {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 1rem 1.5rem;
  }

  .sponsor-item {
    filter: grayscale(1);
    transition: filter 200ms ease;
  }

  .sponsor-item:hover {
    filter: grayscale(0);
  }
</style>
