---
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Section from "./Section.astro";

const cards = [
  {
    index: 0,
    title:
      "Para Cabañas Don Ramiro desarrollamos un sitio web con motor de reservas integrado y sincronización automática con Booking y Airbnb, aumentando las reservas directas y eliminando la dependencia de plataformas de terceros.",
    link: "/portfolio/caba%C3%B1as-don-ramiro",
  },
  {
    index: 1,
    title:
      "Para Tierras Gosén creamos un sitio web conectado a un chatbot de WhatsApp vía ManyChat, automatizando la atención al cliente 24/7 y reduciendo significativamente el tiempo de respuesta a consultas.",
    link: "/portfolio/tierras-gosen",
  },
  {
    index: 2,
    title:
      "Para Ticomotor construimos una aplicación web de compra y venta de autos con inteligencia artificial integrada, posicionándose como referencia en el mercado automotriz costarricense.",
    link: "/portfolio/ticomotor",
  },
];

import larrow from "../../assets/icon3.svg";
import SectionTitle from "../ui/SectionTitle.astro";
---

<Section id="cases">
  <div class="mt-[140px] mb-5">
  <SectionTitle
    sectionTitle="Casos de Éxito"
    description="Resultados reales que hemos logrado para nuestros clientes."
  />
  <div class="flex flex-col lg:flex-row justify-between rounded-[45px] p-1 gap-10">
    {
      cards.map((card) => (
        <Card>
          <div class="flex p-[60px] h-full bg-dark text-gray rounded-[45px] m-[1px]">
            <div class="flex flex-col gap-5">
              <p>{card.title}</p>
              <a href={card.link} class="flex items-center gap-[15px]">
                <span class="text-green">Más Información</span>
                <picture>
                  <Image src={larrow} alt="Arrow pointing up right" />
                </picture>
              </a>
            </div>
          </div>
        </Card>
      ))
    }
  </div>
  </div>
</Section>