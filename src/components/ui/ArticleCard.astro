---
import { formatDate } from "../../utils";
import type { CollectionEntry } from "astro:content";

const { article } = Astro.props;

interface Props {
  article: CollectionEntry<'blog'>;
}

const imageUrl = article.data.image.startsWith('/') 
  ? article.data.image 
  : '/blog/' + article.data.image;
---

<a href={'/articles/' + article.id.replace(/\.md$/, '')} class="article-card group animate-on-scroll">
  <!-- Image -->
  <div class="article-card__img-wrapper">
    <img src={imageUrl} alt={article.data.title} class="article-card__img" />
    <div class="article-card__img-overlay"></div>
  </div>

  <!-- Content -->
  <div class="article-card__body">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-[#fff3e0] text-[#b85c00] border border-[#ff9327]">
        {article.data.type}
      </span>
      <span class="text-xs text-dark/50">{formatDate(article.data.pubDate)}</span>
    </div>

    <h2 class="article-card__title">{article.data.title}</h2>
    <p class="article-card__summary">{article.data.summary}</p>

    <div class="flex items-center justify-between mt-4 pt-4 border-t border-dark/10">
      <div class="flex items-center gap-2">
        <img src={article.data.authImage} alt={article.data.author} class="w-7 h-7 rounded-full object-cover" />
        <span class="text-sm font-medium text-dark">{article.data.author}</span>
      </div>
      <span class="text-sm font-medium text-[#ff9327] group-hover:underline">
        Leer más →
      </span>
    </div>
  </div>
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(25,26,35,0.1);
    box-shadow: 0 4px 0 #191a23;
    background: white;
    transition: transform 200ms ease, box-shadow 200ms ease;
    text-decoration: none;
    color: inherit;
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 0 #191a23;
  }

  .article-card__img-wrapper {
    position: relative;
    overflow: hidden;
    height: 200px;
  }

  .article-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .article-card:hover .article-card__img {
    transform: scale(1.04);
  }

  .article-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.15), transparent);
  }

  .article-card__body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .article-card__title {
    font-size: 1.125rem;
    font-weight: 500;
    color: #191a23;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card__summary {
    font-size: 0.875rem;
    color: rgba(25,26,35,0.6);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
