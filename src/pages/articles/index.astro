---
import MainLayout from "../../layouts/MainLayout.astro";
import ArticleCard from "../../components/ui/ArticleCard.astro";
import { getCollection } from 'astro:content';
import type { CollectionEntry } from "astro:content";

const allBlogArticles: CollectionEntry<'blog'>[] = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<MainLayout title="Blog | Pimenta Studio" description="Artículos, casos de éxito y tendencias del mundo digital.">
  <main class="pt-32 pb-20 px-4 mx-auto max-w-screen-xl">

    <!-- Header -->
    <div class="text-center mb-16">
      <h1 class="text-4xl sm:text-5xl font-medium text-dark mb-4">Blog</h1>
      <p class="text-dark/60 text-lg max-w-xl mx-auto">
        Casos de éxito, tendencias y recursos para hacer crecer tu negocio digital.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3" data-stagger-container>
      {allBlogArticles.map(article => (
        <ArticleCard article={article} />
      ))}
    </div>

  </main>
</MainLayout>
